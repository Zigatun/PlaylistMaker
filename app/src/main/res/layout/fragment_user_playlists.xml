<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_gravity="fill_horizontal">
    <Button
        android:id="@+id/create_new_playlist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        style="@style/RegularAppButton"
        android:text="@string/new_playlist"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        android:textAllCaps="false"/>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="fill_horizontal">
        <LinearLayout
            android:id="@+id/no_items_placeholder"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_horizontal">
            <ImageView
                android:id="@+id/placeholder_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/no_items_icon"
                android:layout_marginTop="46dp"
                android:layout_marginBottom="16dp"
                android:layout_gravity="center_horizontal">
            </ImageView>
            <TextView
                android:id="@+id/error_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textFontWeight="500"
                style="@style/PlaceholderErrorTextStyle"
                android:layout_marginHorizontal="24dp"

                android:text="@string/user_playlists_empty"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible"
            android:indeterminateTint="@color/yp_blue"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="140dp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:visibility="gone"
            android:id="@+id/playlistsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="fill_horizontal"
            android:layout_marginTop="16dp">
        </androidx.recyclerview.widget.RecyclerView>
    </FrameLayout>

</LinearLayout>